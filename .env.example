# Copy this to .env.local and fill in your values
# NEVER commit .env.local to Git

# Amazon Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id
NEXT_PUBLIC_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com

# App URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Java microservice URLs (used by Next.js rewrites)
# In production these will be your ECS service URLs behind the ALB
AUTH_SERVICE_URL=http://localhost:8081
SIGNAL_SERVICE_URL=http://localhost:8082
PRICE_SERVICE_URL=http://localhost:8083
SENTIMENT_SERVICE_URL=http://localhost:8084
WATCHLIST_SERVICE_URL=http://localhost:8085
USER_SERVICE_URL=http://localhost:8086
